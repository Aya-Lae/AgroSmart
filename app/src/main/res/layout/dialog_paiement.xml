<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/card_background"
    android:padding="24dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="20dp">

        <TextView
            android:id="@+id/btn_retour_dialog"
            android:text="←"
            android:textSize="20sp"
            android:textColor="@color/vert_principal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="12dp"/>

        <TextView
            android:text="Payment Details"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#212121"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <!-- Montant -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#F0FFF0"
        android:padding="12dp"
        android:layout_marginBottom="20dp">

        <TextView
            android:text="Total Amount"
            android:textSize="14sp"
            android:textColor="@color/texte_gris"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="$4.99"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/vert_principal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <!-- Numéro carte -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/input_background"
        android:padding="14dp"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <TextView
            android:text="💳"
            android:textSize="18sp"
            android:layout_marginEnd="10dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <EditText
            android:id="@+id/edit_carte"
            android:hint="Card Number"
            android:inputType="number"
            android:maxLength="16"
            android:background="@null"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <!-- MM/YY + CVC -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <EditText
            android:id="@+id/edit_expiry"
            android:hint="MM/YY"
            android:inputType="datetime"
            android:maxLength="5"
            android:background="@drawable/input_background"
            android:padding="14dp"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"/>

        <EditText
            android:id="@+id/edit_cvc"
            android:hint="CVC"
            android:inputType="numberPassword"
            android:maxLength="3"
            android:background="@drawable/input_background"
            android:padding="14dp"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <!-- Nom -->
    <EditText
        android:id="@+id/edit_nom_carte"
        android:hint="Cardholder Name"
        android:background="@drawable/input_background"
        android:padding="14dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"/>

    <!-- Progress -->
    <ProgressBar
        android:id="@+id/progress_paiement"
        android:visibility="gone"
        android:layout_gravity="center"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"/>

    <!-- Résultat -->
    <TextView
        android:id="@+id/txt_resultat"
        android:visibility="gone"
        android:gravity="center"
        android:layout_marginBottom="12dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <!-- Bouton payer -->
    <Button
        android:id="@+id/btn_payer"
        android:text="🔒 Pay $4.99 Securely"
        android:backgroundTint="@color/vert_principal"
        android:textColor="@color/blanc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

</LinearLayout>