<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/blanc">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp">

        <!-- Icône verte -->
        <LinearLayout
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/cercle_vert_clair_bg"
            android:gravity="center"
            android:layout_marginEnd="14dp">

            <ImageView
                android:id="@+id/item_icone"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_plant"
                android:contentDescription="activite"
                app:tint="@color/vert_principal"/>
        </LinearLayout>

        <!-- Contenu -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/item_titre"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"/>

            <!-- Date + Badge type -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="6dp">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_calendrier"
                    android:contentDescription="date"
                    android:layout_marginEnd="4dp"
                    app:tint="@color/texte_gris"/>

                <TextView
                    android:id="@+id/item_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="@color/texte_gris"
                    android:layout_marginEnd="8dp"/>

                <!-- Badge type -->
                <TextView
                    android:id="@+id/item_badge_type"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/badge_type_bg"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:textSize="11sp"
                    android:textColor="@color/vert_principal"
                    android:textStyle="bold"/>
            </LinearLayout>

            <TextView
                android:id="@+id/item_note"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#AAAAAA"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- Menu 3 points -->
        <ImageView
            android:id="@+id/item_menu"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_more"
            android:contentDescription="menu"
            app:tint="@color/texte_gris"
            android:clickable="true"
            android:focusable="true"/>

        <!-- Checkbox caché (garde la logique Java) -->
        <CheckBox
            android:id="@+id/check_faite"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>