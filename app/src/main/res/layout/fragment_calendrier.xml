<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/fond_clair">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/vert_principal"
        android:padding="16dp"
        android:orientation="vertical">

        <TextView
            android:text="@string/titre_calendrier"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/blanc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="@string/sous_titre_calendrier"
            android:textSize="12sp"
            android:textColor="#CCFFCC"
            android:layout_marginTop="4dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <!-- Formulaire ajout -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/blanc"
        android:elevation="4dp"
        android:padding="16dp"
        android:layout_marginBottom="8dp">

        <TextView
            android:text="@string/nouvelle_activite"
            android:textStyle="bold"
            android:textColor="@color/vert_principal"
            android:textSize="15sp"
            android:layout_marginBottom="12dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <EditText
            android:id="@+id/edit_culture"
            android:hint="@string/culture_label"
            android:textColor="#212121"
            android:textColorHint="#9E9E9E"
            android:backgroundTint="@color/vert_clair"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:padding="10dp"/>

        <EditText
            android:id="@+id/edit_type"
            android:hint="@string/type_label"
            android:textColor="#212121"
            android:textColorHint="#9E9E9E"
            android:backgroundTint="@color/vert_clair"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:padding="10dp"/>

        <EditText
            android:id="@+id/edit_date"
            android:hint="@string/date_label"
            android:textColor="#212121"
            android:textColorHint="#9E9E9E"
            android:backgroundTint="@color/vert_clair"
            android:inputType="datetime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:padding="10dp"/>

        <EditText
            android:id="@+id/edit_note"
            android:hint="@string/note_label"
            android:textColor="#212121"
            android:textColorHint="#9E9E9E"
            android:backgroundTint="@color/vert_clair"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:padding="10dp"/>

        <Button
            android:id="@+id/btn_ajouter"
            android:text="@string/btn_ajouter"
            android:backgroundTint="@color/vert_principal"
            android:textColor="@color/blanc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

    </LinearLayout>

    <!-- Liste activités -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_activites"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingTop="4dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false"/>

</LinearLayout>