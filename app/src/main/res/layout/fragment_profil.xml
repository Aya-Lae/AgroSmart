<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fond_clair">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/vert_principal"
            android:padding="24dp"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:text="👤"
                android:textSize="48sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/txt_nom_header"
                android:text="Mon Profil"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/blanc"
                android:layout_marginTop="8dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- Formulaire -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/blanc"
            android:elevation="4dp"
            android:padding="20dp"
            android:layout_margin="16dp">

            <TextView
                android:text="Nom"
                android:textStyle="bold"
                android:textColor="@color/texte_gris"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <EditText
                android:id="@+id/edit_nom"
                android:hint="Votre nom"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:text="Région"
                android:textStyle="bold"
                android:textColor="@color/texte_gris"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <EditText
                android:id="@+id/edit_region"
                android:hint="Ex: Settat, Marrakech..."
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:text="Culture principale"
                android:textStyle="bold"
                android:textColor="@color/texte_gris"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <EditText
                android:id="@+id/edit_culture"
                android:hint="Ex: Blé, Olive, Tomate..."
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"/>

            <Button
                android:id="@+id/btn_sauvegarder"
                android:text="💾 Sauvegarder"
                android:backgroundTint="@color/vert_principal"
                android:textColor="@color/blanc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/txt_confirmation"
                android:text=""
                android:textColor="@color/vert_clair"
                android:gravity="center"
                android:layout_marginTop="8dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

        </LinearLayout>

        <!-- Bouton déconnexion -->
        <Button
            android:id="@+id/btn_deconnexion"
            android:text="🚪 Se déconnecter"
            android:backgroundTint="#F44336"
            android:textColor="@color/blanc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="24dp"/>

    </LinearLayout>
</ScrollView>