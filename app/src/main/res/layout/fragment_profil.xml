<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fond_clair">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header vert avec feuilles décoratives -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="240dp"
            android:background="@color/vert_principal">

            <!-- Cercles décoratifs feuilles -->
            <View
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="top|start"
                android:layout_margin="16dp"
                android:background="@drawable/cercle_feuille_gauche"
                android:alpha="0.3"/>

            <View
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="top|end"
                android:layout_margin="16dp"
                android:background="@drawable/cercle_feuille_droite"
                android:alpha="0.3"/>

            <!-- Contenu header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="24dp">

                <TextView
                    android:text="Mon profil"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/blanc"
                    android:layout_marginBottom="16dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <!-- Avatar -->
                <FrameLayout
                    android:layout_width="90dp"
                    android:layout_height="90dp"
                    android:layout_gravity="center">

                    <TextView
                        android:id="@+id/txt_avatar"
                        android:text="A"
                        android:textSize="36sp"
                        android:textStyle="bold"
                        android:textColor="@color/texte_gris"
                        android:gravity="center"
                        android:background="@drawable/cercle_avatar_blanc"
                        android:layout_width="90dp"
                        android:layout_height="90dp"/>

                    <!-- Bouton edit -->
                    <TextView
                        android:text="✏️"
                        android:textSize="14sp"
                        android:gravity="center"
                        android:background="@drawable/cercle_edit"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="bottom|end"/>

                </FrameLayout>

                <TextView
                    android:id="@+id/txt_nom_header"
                    android:text=""
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/blanc"
                    android:layout_marginTop="8dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/txt_email_header"
                    android:text=""
                    android:textSize="13sp"
                    android:textColor="#AAFFFFFF"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

            </LinearLayout>
        </FrameLayout>

        <!-- Carte infos compte -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/blanc"
            android:elevation="2dp"
            android:layout_margin="16dp">

            <!-- Région -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:gravity="center"
                    android:background="@drawable/cercle_icone_vert">
                    <TextView android:text="📍" android:textSize="18sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">
                    <TextView android:text="Région" android:textSize="11sp"
                        android:textColor="@color/texte_gris"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                    <EditText android:id="@+id/edit_region"
                        android:textSize="15sp" android:textColor="#212121"
                        android:background="@null"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

                <TextView android:text="✏" android:textSize="16sp"
                    android:textColor="@color/texte_gris"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#F0F0F0" android:layout_marginStart="68dp"/>

            <!-- Nom -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:gravity="center"
                    android:background="@drawable/cercle_icone_vert">
                    <TextView android:text="👤" android:textSize="18sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">
                    <TextView android:text="Nom" android:textSize="11sp"
                        android:textColor="@color/texte_gris"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                    <EditText android:id="@+id/edit_nom"
                        android:textSize="15sp" android:textColor="#212121"
                        android:background="@null"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

                <TextView android:text="✏" android:textSize="16sp"
                    android:textColor="@color/texte_gris"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#F0F0F0" android:layout_marginStart="68dp"/>

            <!-- Email -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:gravity="center"
                    android:background="@drawable/cercle_icone_vert">
                    <TextView android:text="✉️" android:textSize="18sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">
                    <TextView android:text="Email" android:textSize="11sp"
                        android:textColor="@color/texte_gris"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                    <TextView android:id="@+id/txt_email_detail"
                        android:textSize="15sp" android:textColor="#212121"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

                <TextView android:text="✏" android:textSize="16sp"
                    android:textColor="@color/texte_gris"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- Culture -->
            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#F0F0F0" android:layout_marginStart="68dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:gravity="center"
                    android:background="@drawable/cercle_icone_vert">
                    <TextView android:text="🌾" android:textSize="18sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">
                    <TextView android:text="Culture" android:textSize="11sp"
                        android:textColor="@color/texte_gris"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                    <EditText android:id="@+id/edit_culture"
                        android:textSize="15sp" android:textColor="#212121"
                        android:background="@null"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

                <TextView android:text="✏" android:textSize="16sp"
                    android:textColor="@color/texte_gris"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

        </LinearLayout>

        <!-- Bouton sauvegarder -->
        <Button
            android:id="@+id/btn_sauvegarder"
            android:text="Sauvegarder"
            android:backgroundTint="@color/vert_accent"
            android:textColor="@color/blanc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/txt_confirmation"
            android:gravity="center"
            android:textColor="@color/vert_accent"
            android:layout_marginBottom="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <!-- Carte Chatbot avancé -->
        <LinearLayout
            android:id="@+id/carte_activer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/blanc"
            android:elevation="3dp"
            android:padding="20dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="12dp"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <!-- Icône couronne -->
                <LinearLayout
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:gravity="center"
                    android:background="@drawable/cercle_vert_fonce"
                    android:layout_marginEnd="12dp">
                    <TextView android:text="👑" android:textSize="22sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:text="Chatbot avancé (API)"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/vert_principal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                    <TextView
                        android:text="Débloquez tout le potentiel du chatbot"
                        android:textSize="12sp"
                        android:textColor="@color/texte_gris"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

                <!-- Icône chat décorative -->
                <TextView android:text="💬" android:textSize="32sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

            </LinearLayout>

            <!-- Features -->
            <LinearLayout android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:orientation="horizontal"
                android:layout_marginBottom="6dp">
                <TextView android:text="✅ " android:textColor="@color/vert_accent"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:text="Réponses plus précises et détaillées"
                    android:textSize="13sp" android:textColor="#444"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>
            <LinearLayout android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:orientation="horizontal"
                android:layout_marginBottom="6dp">
                <TextView android:text="✅ " android:textColor="@color/vert_accent"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:text="Accès aux modèles avancés"
                    android:textSize="13sp" android:textColor="#444"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>
            <LinearLayout android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:orientation="horizontal"
                android:layout_marginBottom="16dp">
                <TextView android:text="✅ " android:textColor="@color/vert_accent"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:text="Expérience sans limite"
                    android:textSize="13sp" android:textColor="#444"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- Bouton payer -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/btn_vert_arrondi"
                android:orientation="horizontal"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:id="@+id/btn_payer_activer">

                <TextView android:text="🔒 " android:textSize="16sp"
                    android:textColor="@color/blanc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:id="@+id/txt_statut_chatbot"
                    android:text="Payer pour activer"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/blanc"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"/>
                <TextView android:text=" ›" android:textSize="20sp"
                    android:textColor="@color/blanc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

        </LinearLayout>

        <!-- Carte liens secondaires -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/blanc"
            android:elevation="2dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="12dp">

            <!-- Historique paiements -->
            <LinearLayout
                android:id="@+id/btn_historique"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:gravity="center"
                    android:background="@drawable/cercle_icone_vert">
                    <TextView android:text="💳" android:textSize="18sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

                <TextView
                    android:text="Historique des paiements"
                    android:textSize="15sp"
                    android:textColor="#212121"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"/>

                <TextView android:text="›" android:textSize="22sp"
                    android:textColor="@color/texte_gris"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#F0F0F0" android:layout_marginStart="68dp"/>

            <!-- Aide et support -->
            <LinearLayout
                android:id="@+id/btn_aide"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:gravity="center"
                    android:background="@drawable/cercle_icone_vert">
                    <TextView android:text="❓" android:textSize="18sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

                <TextView
                    android:text="Aide et support"
                    android:textSize="15sp"
                    android:textColor="#212121"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"/>

                <TextView android:text="›" android:textSize="22sp"
                    android:textColor="@color/texte_gris"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

        </LinearLayout>

        <!-- Bouton déconnexion -->
        <LinearLayout
            android:id="@+id/btn_deconnexion"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@color/carte_bg"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="32dp"
            android:clickable="true"
            android:focusable="true">

            <TextView android:text="↪ " android:textSize="18sp"
                android:textColor="@color/dore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <TextView
                android:text="Se déconnecter"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/dore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>