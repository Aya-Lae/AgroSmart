<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header vert avec avatar -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:background="@color/vert_principal">

            <!-- Cercles décoratifs -->
            <View
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="-40dp"
                android:layout_marginEnd="-40dp"
                android:background="@drawable/cercle_vert"
                android:alpha="0.2"/>

            <View
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="bottom|start"
                android:layout_marginStart="-30dp"
                android:layout_marginBottom="-30dp"
                android:background="@drawable/cercle_vert"
                android:alpha="0.15"/>

            <!-- Avatar + nom -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center">

                <!-- Avatar cercle avec initiale -->
                <FrameLayout
                    android:layout_width="80dp"
                    android:layout_height="80dp">

                    <TextView
                        android:id="@+id/txt_avatar"
                        android:text="A"
                        android:textSize="32sp"
                        android:textStyle="bold"
                        android:textColor="@color/blanc"
                        android:gravity="center"
                        android:background="@drawable/cercle_avatar"
                        android:layout_width="80dp"
                        android:layout_height="80dp"/>

                </FrameLayout>

                <TextView
                    android:id="@+id/txt_nom_header"
                    android:text="Mon Profil"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/blanc"
                    android:layout_marginTop="8dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/txt_email_header"
                    android:textSize="13sp"
                    android:textColor="#CCFFFFFF"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

            </LinearLayout>
        </FrameLayout>

        <!-- Carte statut chatbot -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_margin="16dp">

            <!-- Statut chatbot -->
            <LinearLayout
                android:id="@+id/carte_chatbot"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/card_background"
                android:padding="16dp"
                android:elevation="4dp"
                android:layout_marginEnd="8dp">

                <TextView
                    android:text="🤖"
                    android:textSize="28sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/txt_statut_chatbot"
                    android:text="Simulé"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/texte_gris"
                    android:layout_marginTop="4dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:text="Mode Chatbot"
                    android:textSize="11sp"
                    android:textColor="@color/texte_gris"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

            </LinearLayout>

            <!-- Activer Claude -->
            <LinearLayout
                android:id="@+id/carte_activer"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/btn_green"
                android:padding="16dp"
                android:elevation="4dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:text="⭐"
                    android:textSize="28sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:text="Activer Claude"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/blanc"
                    android:layout_marginTop="4dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:text="4.99$ / mois"
                    android:textSize="11sp"
                    android:textColor="#CCFFFFFF"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

            </LinearLayout>

        </LinearLayout>

        <!-- Carte Account Details -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/blanc"
            android:elevation="4dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="12dp"
            android:padding="16dp">

            <TextView
                android:text="Account Details"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#212121"
                android:layout_marginBottom="16dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <!-- Nom -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:text="👤"
                    android:textSize="20sp"
                    android:layout_width="40dp"
                    android:layout_height="wrap_content"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:text="Nom"
                        android:textSize="11sp"
                        android:textColor="@color/texte_gris"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <EditText
                        android:id="@+id/edit_nom"
                        android:textSize="15sp"
                        android:textColor="#212121"
                        android:background="@null"
                        android:hint="Votre nom"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Email -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:text="✉️"
                    android:textSize="20sp"
                    android:layout_width="40dp"
                    android:layout_height="wrap_content"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:text="Email"
                        android:textSize="11sp"
                        android:textColor="@color/texte_gris"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:id="@+id/txt_email_detail"
                        android:textSize="15sp"
                        android:textColor="#212121"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Région -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:text="📍"
                    android:textSize="20sp"
                    android:layout_width="40dp"
                    android:layout_height="wrap_content"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:text="Région"
                        android:textSize="11sp"
                        android:textColor="@color/texte_gris"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <EditText
                        android:id="@+id/edit_region"
                        android:textSize="15sp"
                        android:textColor="#212121"
                        android:background="@null"
                        android:hint="Votre région"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Culture -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:text="🌾"
                    android:textSize="20sp"
                    android:layout_width="40dp"
                    android:layout_height="wrap_content"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:text="Culture"
                        android:textSize="11sp"
                        android:textColor="@color/texte_gris"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <EditText
                        android:id="@+id/edit_culture"
                        android:textSize="15sp"
                        android:textColor="#212121"
                        android:background="@null"
                        android:hint="Votre culture"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>

        <!-- Bouton Sauvegarder -->
        <Button
            android:id="@+id/btn_sauvegarder"
            android:text="@string/sauvegarder"
            android:backgroundTint="@color/vert_principal"
            android:textColor="@color/blanc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/txt_confirmation"
            android:gravity="center"
            android:textColor="@color/vert_clair"
            android:layout_marginBottom="8dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <!-- Déconnexion -->
        <Button
            android:id="@+id/btn_deconnexion"
            android:text="@string/se_deconnecter"
            android:backgroundTint="#F44336"
            android:textColor="@color/blanc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="24dp"/>

    </LinearLayout>
</ScrollView>